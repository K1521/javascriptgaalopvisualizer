      float r = a1.x / a1.y;
      float m = max(max(abs(y), abs(r)), 1.0);
      if (abs(mod(a1.y, 2.0) - 1.0) < 0.01 && abs((r - y)/y) < 0.00001) {
        return (mod(a1.x, 2.0) == 0.0 ? 1.0 : -1.0) * pow(-x, y);
