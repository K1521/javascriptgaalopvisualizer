// Toren
?T1 = Toroid(3,1);
?T2 = Toroid(3,1);


// Transformationen
Tr = Translator(tx,ty,tz);
R  = Rotor(ax,ay,az,angle);

// Motor (Rotation + Translation)
M = R * Tr;


// transformierter Torus
?T2m = M * T2 * ~M;


// Schnittkurve
?CurveTT = T1 ^ T2m;


// Anzeige
:Blue;
:T1;

:Red;
:T2m;

:Green;
:CurveTT;


